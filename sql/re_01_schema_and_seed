-- ============================================================
-- TABLE 1: global_price_index
-- Annual house price index per country (2000=100)
-- ============================================================
CREATE TABLE global_price_index (
    id          SERIAL PRIMARY KEY,
    country     VARCHAR(30) NOT NULL,
    year        SMALLINT    NOT NULL,
    hpi         NUMERIC(7,2),           -- index: 2000=100
    yoy_pct     NUMERIC(6,2),
    cycle_phase VARCHAR(20),
    UNIQUE(country, year)
);

