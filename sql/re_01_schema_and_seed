-- TABLE 2: global_market_events
-- Key events driving each cycle phase
-- ============================================================
CREATE TABLE global_market_events (
    event_id    SERIAL PRIMARY KEY,
    event_date  DATE NOT NULL,
    event_name  VARCHAR(80),
    event_type  VARCHAR(20),   -- 'catalyst','shock','policy','turning_point'
    impact      VARCHAR(20),   -- 'bullish','bearish','mixed'
    countries_affected TEXT,
    price_impact_pct NUMERIC(6,2),
    description TEXT
);

